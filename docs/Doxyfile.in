PROJECT_NAME           = "WIRBLE"
PROJECT_NUMBER         = "@WIRBLE_PROJECT_VERSION@"
PROJECT_BRIEF          = "Rewrite-driven compiler infrastructure and toolchain."
OUTPUT_DIRECTORY       = "@WIRBLE_OUTPUT_DIRECTORY@"
OUTPUT_LANGUAGE        = English
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = "@WIRBLE_TOP_SRCDIR@"
STRIP_FROM_INC_PATH    = "@WIRBLE_STRIP_FROM_INC_PATH@"
LAYOUT_FILE            = "@WIRBLE_LAYOUT_FILE@"

INPUT                  = "@WIRBLE_TOP_SRCDIR@/README.md" \
                         "@WIRBLE_TOP_SRCDIR@/include" \
                         "@WIRBLE_TOP_SRCDIR@/src/wirble"
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = YES
EXCLUDE                = "@WIRBLE_TOP_SRCDIR@/third_party" \
                         "@WIRBLE_TOP_SRCDIR@/build" \
                         "@WIRBLE_TOP_SRCDIR@/.git"
EXCLUDE_SYMLINKS       = YES

USE_MDFILE_AS_MAINPAGE = "@WIRBLE_TOP_SRCDIR@/README.md"
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 3
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = NO
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
EXTRACT_LOCAL_METHODS  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = NO
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = YES
INLINE_SOURCES         = NO
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
SOURCE_TOOLTIPS        = YES
USE_HTAGS              = NO
VERBATIM_HEADERS       = YES
CLANG_ASSISTED_PARSING = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_NO_PARAMDOC       = NO
WARN_LOGFILE           = "@WIRBLE_WARN_LOGFILE@"

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = AUTO_LIGHT
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = YES
HTML_INDEX_NUM_ENTRIES = 100
DISABLE_INDEX          = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
ENUM_VALUES_PER_LINE   = 1
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
USE_PDFLATEX           = YES
PDF_HYPERLINKS         = YES
LATEX_BATCHMODE        = NO
LATEX_HIDE_INDICES     = NO
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
MAKEINDEX_CMD_NAME     = makeindex

GENERATE_MAN           = YES
MAN_OUTPUT             = man
MAN_EXTENSION          = .3wil
MAN_SUBDIR             = man3wil
MAN_LINKS              = YES

GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = YES

GENERATE_RTF           = NO

GENERATE_DOCBOOK       = YES
DOCBOOK_OUTPUT         = docbook

GENERATE_AUTOGEN_DEF   = YES
GENERATE_PERLMOD       = NO
GENERATE_SQLITE3       = NO

HAVE_DOT               = @WIRBLE_HAVE_DOT@
CALL_GRAPH             = @WIRBLE_HAVE_DOT@
CALLER_GRAPH           = @WIRBLE_HAVE_DOT@
CLASS_GRAPH            = @WIRBLE_HAVE_DOT@
COLLABORATION_GRAPH    = @WIRBLE_HAVE_DOT@
GROUP_GRAPHS           = @WIRBLE_HAVE_DOT@
DIRECTORY_GRAPH        = @WIRBLE_HAVE_DOT@
INCLUDE_GRAPH          = @WIRBLE_HAVE_DOT@
INCLUDED_BY_GRAPH      = @WIRBLE_HAVE_DOT@
GRAPHICAL_HIERARCHY    = @WIRBLE_HAVE_DOT@
DOT_IMAGE_FORMAT       = svg
DOT_MULTI_TARGETS      = YES
INTERACTIVE_SVG        = YES
DOT_NUM_THREADS        = 0
UML_LOOK               = YES
TEMPLATE_RELATIONS     = YES
